{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Current File (Node)",
			"program": "${file}",
			"cwd": "${workspaceFolder}",
			"runtimeArgs": ["--experimental-strip-types", "--enable-source-maps"],
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
