{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"allowJs": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"paths": {
			"dbtyper": ["../../src/index.ts"],
			"dbtyper/postgres": ["../../src/postgres/index.ts"],
			"@dbtyper/nest": ["../../packages/dbtyper-nest/src/index.ts"]
		},
		"ignoreDeprecations": "6.0"
	},
	"include": ["src/**/*.ts", "migrations/**/*.js", "scripts/**/*.ts", "test/**/*.ts"],
	"exclude": ["../../test/fail-to-compile.ts"]
}
