{
	"name": "jsql",
	"version": "1.0.0",
	"description": "",
	"license": "ISC",
	"author": "",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"typecheck": "time tsgo --noEmit -p tsconfig.json",
		"tsc": "time tsc --noEmit -p tsconfig.json",
		"test": "npm run --silent typecheck && npm run --silent borrowcheck && node --test \"src/**/*.test.ts\"",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"borrowcheck": "node src/type-checker/check-consumption.ts 'src/parser/**/*.ts' 'src/engine/**/*.ts'",
		"borrowcheck-test-1": "node src/type-checker/check-consumption.ts 'src/type-checker/test-data/1/*.ts'",
		"borrowcheck-test-2": "node src/type-checker/check-consumption.ts 'src/type-checker/test-data/2/*.ts'"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"@typescript/native-preview": "^7.0.0-dev.20260408.1",
		"prettier": "^3.8.1",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"fast-glob": "^3.3.3"
	}
}
