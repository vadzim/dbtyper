{
	"name": "jsql",
	"version": "1.0.0",
	"description": "",
	"license": "ISC",
	"author": "",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"typecheck": "time tsgo --noEmit -p tsconfig.json && npm run --silent monadcheck",
		"test": "npm run --silent typecheck && node --test \"test/**/*.test.ts\"",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"monadcheck": "time check-monad './core/**/*.ts' './src/**/*.ts' --monad ./core/sql-tokens.ts TokensList:ParseSqlTokens:PeekToken:SkipToken --snippet-lines 6:4"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"@typescript/native-preview": "^7.0.0-dev.20260408.1",
		"prettier": "^3.8.1",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"fast-glob": "^3.3.3"
	}
}
