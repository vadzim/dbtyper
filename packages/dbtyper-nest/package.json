{
	"name": "@dbtyper/nest",
	"version": "0.1.0",
	"description": "NestJS integration for dbtyper (compiled schema + SqlDriver lifecycle).",
	"type": "module",
	"license": "ISC",
	"keywords": [
		"dbtyper",
		"nestjs",
		"sql"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"peerDependencies": {
		"@nestjs/common": "^10.0.0 || ^11.0.0",
		"@nestjs/core": "^10.0.0 || ^11.0.0",
		"dbtyper": "*"
	},
	"devDependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"prettier": "^3.8.1",
		"dbtyper": "file:../.."
	},
	"scripts": {
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"format:check": "prettier --check .",
		"test": "npm run typecheck && npm run format:check"
	}
}
