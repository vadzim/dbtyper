{
	"name": "dbtyper-nest",
	"version": "0.1.0",
	"description": "NestJS integration for dbtyper (compiled schema + SqlDriver lifecycle).",
	"type": "module",
	"license": "ISC",
	"author": "vadzimzienka@gmail.com",
	"keywords": [
		"dbtyper",
		"nestjs",
		"sql"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vadzim/dbtyper.git",
		"directory": "packages/dbtyper-nest"
	},
	"bugs": {
		"url": "https://github.com/vadzim/dbtyper/issues"
	},
	"homepage": "https://github.com/vadzim/dbtyper/tree/main/packages/dbtyper-nest#readme",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"DESIGN.md"
	],
	"peerDependencies": {
		"@nestjs/common": "^10.0.0 || ^11.0.0",
		"@nestjs/core": "^10.0.0 || ^11.0.0",
		"dbtyper": "*"
	},
	"devDependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"prettier": "^3.8.1",
		"dbtyper": "file:../.."
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist",
		"prepack": "npm run clean && npm run build",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"format:check": "prettier --check .",
		"test": "npm run typecheck && npm run format:check"
	}
}
