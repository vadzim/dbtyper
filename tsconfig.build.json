{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"allowJs": true,
		"outDir": "./dist",
		"rootDir": ".",
		"rewriteRelativeImportExtensions": true
	},
	"include": ["core/**/*.ts", "src/**/*.ts"],
	"exclude": ["test", "migrations", "scripts", "examples", "node_modules", "dist"]
}
